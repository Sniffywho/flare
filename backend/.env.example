# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/chatapp
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/chatapp
MONGO_URI=mongodb://localhost:27017/chatapp

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_long_random_string_access
JWT_REFRESH_SECRET=replace_with_a_long_random_string_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Redis (optional) ─────────────────────────────────────────────────────────
# Leave empty to disable Redis; the app works without it
REDIS_URL=redis://localhost:6379

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the frontend dev server (Vite default)
CLIENT_URL=http://localhost:5173

# ─── File Storage — Cloudinary (optional) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Firebase Push Notifications (optional) ──────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── OAuth (Google & Apple) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_SERVICE_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:5000/api/auth/apple/callback
